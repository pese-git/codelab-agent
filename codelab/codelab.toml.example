# CodeLab Configuration Template
#
# Скопируйте этот файл в codelab.toml и настройте под ваш проект.
# Приоритет конфигурации (от lowest к highest):
# 1. ~/.codelab/auth.toml — глобальные API keys
# 2. codelab.toml — этот файл (проект)
# 3. codelab.local.toml — project-local overrides (в .gitignore)
# 4. Custom path через --config CLI аргумент

[llm]
# Активный провайдер: openai, anthropic, openrouter, zen, go, ollama, lmstudio, mock
provider = "openai"

# Модель в формате "provider/model"
model = "openai/gpt-4o"

# Параметры генерации
temperature = 0.7
max_tokens = 8192

# ============================================================================
# Таймауты HTTP-вызовов LLM провайдера
# ============================================================================
# Все значения в секундах. Увеличьте read таймаут для медленных моделей
# или при работе с большими контекстами.

[llm.timeout]
# Подключение к серверу API
connect = 30.0
# Ожидание ответа от LLM (генерация completion)
read = 300.0
# Отправка запроса
write = 30.0
# Ожидание соединения из пула
pool = 30.0

# ============================================================================
# Конфигурация провайдеров
# ============================================================================

[llm.providers.openai]
# API ключ можно указать напрямую или через переменную окружения
api_key = "${OPENAI_API_KEY}"
base_url = "https://api.openai.com/v1"
default_model = "gpt-4o"

# Per-provider таймауты (переопределяют [llm.timeout])
# [llm.providers.openai.timeout]
# connect = 30.0
# read = 300.0
# write = 30.0
# pool = 30.0

# Per-model конфигурация
[llm.providers.openai.models.gpt-4o]
context_window = 128000
max_output_tokens = 16384
# cost_per_input_token = 0.0000025
# cost_per_output_token = 0.00001

[llm.providers.openai.models.o3]
context_window = 200000
max_output_tokens = 100000

[llm.providers.openai.models.o4-mini]
context_window = 200000
max_output_tokens = 100000

# ----------------------------------------------------------------------------

[llm.providers.anthropic]
api_key = "${ANTHROPIC_API_KEY}"
base_url = "https://api.anthropic.com"
default_model = "claude-sonnet-4"

[llm.providers.anthropic.models.claude-sonnet-4]
context_window = 200000
max_output_tokens = 64000

[llm.providers.anthropic.models.claude-opus-4]
context_window = 200000
max_output_tokens = 32000

# ----------------------------------------------------------------------------

[llm.providers.openrouter]
api_key = "${OPENROUTER_API_KEY}"
base_url = "https://openrouter.ai/api/v1"
default_model = "mistral-large"

[llm.providers.openrouter.models.mistral-large]
context_window = 128000
max_output_tokens = 64000

[llm.providers.openrouter.models.llama-3.1-70b]
context_window = 128000
max_output_tokens = 8192

# ----------------------------------------------------------------------------

[llm.providers.zen]
api_key = "${ZEN_API_KEY}"
base_url = "https://zen.opencode.ai/v1"
default_model = "zen-sonnet"

# ----------------------------------------------------------------------------

[llm.providers.go]
api_key = "${GO_API_KEY}"
base_url = "https://go.opencode.ai/v1"
default_model = "go-fast"

# ----------------------------------------------------------------------------

[llm.providers.ollama]
# Ollama обычно не требует API key
base_url = "http://localhost:11434/v1"
default_model = "llama3.1:70b"

[llm.providers.ollama.models.llama3.1-70b]
context_window = 128000
max_output_tokens = 8192

[llm.providers.ollama.models.mistral]
context_window = 32000
max_output_tokens = 8192

# ----------------------------------------------------------------------------

[llm.providers.lmstudio]
base_url = "http://localhost:1234/v1"
default_model = "local-model"

# ============================================================================
# Fallback система
# ============================================================================

[llm.fallback]
# Включить fallback при ошибках провайдера
enabled = false

# Стратегия: sequential (MVP), cost, latency, smart (future)
strategy = "sequential"

# Порядок провайдеров для fallback
order = ["openai", "openrouter", "ollama"]

# Максимальное количество попыток
max_attempts = 3

# Типы ошибок для retry: rate_limit, timeout, internal_error, service_unavailable
retry_on = ["rate_limit", "timeout"]

# ============================================================================
# Конфигурация мультиагентной системы
# ============================================================================
# Агенты можно определить двумя способами:
#
# 1. TOML (в этом файле) — аналогично opencode.json:
#    [agents.definitions.coder]
#    description = "Senior Python Developer"
#    mode = "subagent"
#    model = "anthropic/claude-3-5-sonnet"
#    prompt = "Ты — Senior Python Developer..."
#
# 2. Markdown файлы (приоритет выше, override TOML):
#    Глобальные: ~/.codelab/agents/*.md
#    Проектные:  .codelab/agents/*.md
#
# Имя файла = имя агента (coder.md → "coder")
# Frontmatter = конфигурация, тело файла = system prompt

# Пример TOML-агента (раскомментируйте для использования):
# [agents.definitions.coder]
# description = "Senior Python Developer"
# mode = "subagent"
# priority = 1
# model = "anthropic/claude-3-5-sonnet"
# temperature = 0.1
# prompt = "Ты — Senior Python Developer. Пиши чистый, типизированный код."
#
# [agents.definitions.coder.tools]
# "fs/read_text_file" = true
# "fs/write_text_file" = true
#
# [agents.definitions.coder.permission]
# edit = "ask"

[agents]
# Стратегия выполнения по умолчанию: single | multi_orchestrated | multi_choreographed | hierarchical
strategy = "single"

# Стратегия fallback если нет нужных агентов для выбранной стратегии
fallback_strategy = "single"

# Модель по умолчанию (если агент не указал свою)
default_model = "openai/gpt-4o"

# Максимальное количество шагов мультиагентного выполнения
max_steps = 7

# Модель для Token-Slicing (дешёвая)
slicer_model = "openai/gpt-4o-mini"

# Лимит токенов для summary
max_sliced_tokens = 120

# Не сжимать если output < N токенов
slicer_skip_threshold = 300

# Лимит контекста (триггер compaction)
context_window_limit = 128000

# Debug mode (полные payload логи, LLM dump)
debug = false

# ============================================================================
# Конфигурация TUI клиента
# ============================================================================

[tui]
# Тема интерфейса: light или dark
# light — светлая тема с холодными тонами (по умолчанию)
# dark — тёмная тема Tokyo Night с улучшенным контрастом
theme = "light"

# Адрес сервера (опционально, можно указать через CLI --host)
# host = "127.0.0.1"

# Порт сервера (опционально, можно указать через CLI --port)
# port = 8765

# Таймаут ожидания ответа от сервера в секундах (по умолчанию: 300)
# Увеличьте при работе с медленными LLM API или stdio транспортом
# receive_timeout = 300

# ============================================================================
# Конфигурация MCP серверов
# ============================================================================
# MCP (Model Context Protocol) серверы подключаются автоматически при создании
# или загрузке сессии. Поддерживаемые типы: "stdio" и "http".
#
# ВАЖНО: Не храните API keys напрямую в TOML файлах.
# Используйте переменные окружения: ${API_KEY}
#
# Переменные окружения в формате ${VAR_NAME} раскрываются автоматически.
# Если переменная не установлена, она заменяется на пустую строку.

# Пример: stdio MCP сервер (локальный процесс)
[[mcp.servers]]
name = "filesystem"
type = "stdio"
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "${PROJECT_ROOT}"]

# Пример: HTTP MCP сервер (удалённый)
[[mcp.servers]]
name = "github"
type = "http"
url = "https://api.githubcopilot.com/mcp"
headers = [
    { name = "Authorization", value = "Bearer ${GITHUB_TOKEN}" },
]

# Пример: stdio сервер с переменными окружения
[[mcp.servers]]
name = "database"
type = "stdio"
command = "python"
args = ["-m", "mcp_server_database"]
env = [
    { name = "DATABASE_URL", value = "${DATABASE_URL}" },
    { name = "DEBUG", value = "true" },
]
